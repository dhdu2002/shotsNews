# 앱 기본 설정
APP_NAME=DailyIssueDesktop
APP_TIMEZONE=Asia/Seoul
APP_TOP_K=5
APP_MAX_CANDIDATES=20
APP_REQUEST_TIMEOUT_SECONDS=15
APP_SCHEDULER_INTERVAL_MINUTES=60

# 소스 수집 설정 (공용 fallback 풀)
APP_RSS_URLS=https://hnrss.org/frontpage,https://www.theverge.com/rss/index.xml
APP_YOUTUBE_FEED_URLS=
APP_REDDIT_SUBREDDITS=technology,MachineLearning
APP_REDDIT_USER_AGENT=daily-issue-desktop/0.1

# Notion 동기화 설정
NOTION_DATABASE_ID=
NOTION_TOKEN=
NOTION_ENABLED=false

# OpenAI 설정
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

# Twitter/X 설정 (선택)
TWITTER_BEARER_TOKEN=
TWITTER_QUERY=ai OR technology

# 카테고리별 분리가 필요하면 config/source_pools.example.json을 참고해
# config/source_pools.json 파일을 추가로 만들 수 있습니다.
